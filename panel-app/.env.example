# RE/MAX Lavanda Portal — environment değişkenleri
# Bu dosyayı kopyalayıp ".env" adıyla kaydet ve gerçek değerleri gir.
# ".env" asla Git'e eklenmez (bkz. .gitignore) — sadece bu ÖRNEK dosya repoda durur.

# Supabase Project Settings → API sayfasından alınır.
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ASLA buraya service_role key veya veritabanı şifresi YAZMA.
# service_role key tüm RLS kurallarını bypass eder — sadece sunucu
# tarafında (ör. Supabase Edge Functions) kullanılmalı, frontend'e asla girmez.

# Veri kaynağı: "mock" (varsayılan, Supabase olmadan geliştirme) | "supabase"
# NOT: production build'de (npm run build) bu değişken ne olursa olsun
# uygulama HER ZAMAN Supabase kullanır — mock veri production'a asla girmez.
VITE_DATA_SOURCE=mock
