{
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "panel.remaxlavanda.com.tr"
        }
      ],
      "destination": "/panel/index.html"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "panel.remaxlavanda.com.tr"
        }
      ],
      "destination": "/panel/:path*"
    }
  ]
}
